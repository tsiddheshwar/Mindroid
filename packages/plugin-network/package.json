{
  "name": "@mindroid/plugin-network",
  "version": "0.1.0",
  "description": "Mindroid plugin for Android network and Wi-Fi state",
  "keywords": [
    "mindroid",
    "android",
    "plugin",
    "network",
    "wifi"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "if exist dist rmdir /s /q dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mindroid/core": "0.1.0"
  }
}
