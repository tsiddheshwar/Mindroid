{
  "name": "mindroid",
  "version": "0.2.0",
  "description": "Mindroid CLI for creating and building JS-first Android apps",
  "keywords": [
    "mindroid",
    "android",
    "cli",
    "apk",
    "aab"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "mindroid": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "if exist dist rmdir /s /q dist",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mindroid/icon-builder": "0.2.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "vitest": "^3.1.3"
  }
}
